# --- Database ---
# SQLAlchemy connection string. Example for local Postgres:
DATABASE_URL=postgresql://study_user:devpass@localhost:5432/studybud

# --- Auth / JWT ---
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- LLM (OpenRouter) ---
# Get a key at https://openrouter.ai/keys
#free models: owl-alpha, Nemotron 3 super
# fast models and free : nvidia/nemotron-3-nano-30b-a3b:free , openai/gpt-oss-120b:free 
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
